# Copy to .env and adjust. The server reads these on startup (Rule 3: UTC everywhere,
# Rule 7: SQLx). Never commit a real .env (see .gitignore).

# ---- API server ----
SERVER_HOST=0.0.0.0
# 9000 by default. (Desktop app runs on :3000, admin dashboard on :3001.)
SERVER_PORT=9000
RUST_LOG=info,server=debug,sqlx=warn

# ---- PostgreSQL (server source of truth) ----
# Matches docker-compose.yml credentials.
DATABASE_URL=postgres://timetracker:timetracker@localhost:5432/timetracker
DATABASE_MAX_CONNECTIONS=10

# ---- Object storage: MinIO (local) / Cloudflare R2 (production) ----
# Rule 5: server stores only metadata; bytes live in R2/MinIO.
# MinIO's S3 API is published on :9100 (host :9000 is the API server).
S3_ENDPOINT=http://localhost:9100
S3_REGION=us-east-1
S3_BUCKET=screenshots
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ---- Auth (Rule 6) — placeholders, wired in a later step ----
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ---- Linear integration (STEP 8) ----
# Server-side ONLY (never sent to clients). Create a Personal API key at
# Linear → Settings → Security & access → Personal API keys. Leave empty to
# disable the integration (the /me/tickets endpoints return a clear error).
LINEAR_API_KEY=

# ---- Ticket access requests (email approval) ----
# Public base URL used in approve/reject links emailed to ticket owners.
PUBLIC_BASE_URL=http://localhost:9000
# SMTP for approval emails. Leave SMTP_HOST empty to run in "log mode" — the
# server logs the email + approve/reject links instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=timetracker@localhost

# ---- Vision AI: screenshot analyzer ----
# Anthropic API key (server-side ONLY, never sent to clients). Create at
# https://console.anthropic.com/. Leave empty to disable analysis (the
# /admin/users/:id/analyze endpoint returns a clear "not configured" error).
ANTHROPIC_API_KEY=
# Override the model if needed (defaults to claude-haiku-4-5-20251001).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Admin dashboard ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:9000
