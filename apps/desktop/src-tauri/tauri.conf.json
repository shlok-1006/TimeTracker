{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeTracker",
  "version": "0.1.4",
  "identifier": "com.timetracker.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter desktop dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm --filter desktop build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TimeTracker",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Employee time tracking",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
