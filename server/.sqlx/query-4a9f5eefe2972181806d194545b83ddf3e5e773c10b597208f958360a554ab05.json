  "query": "SELECT t.id, t.name, t.description, t.created_at,\n                  CAST(COUNT(ut.user_id) AS BIGINT) AS \"member_count!\"\n           FROM teams t\n           LEFT JOIN user_teams ut ON ut.team_id = t.id\n           GROUP BY t.id, t.name, t.description, t.created_at\n           ORDER BY t.name",
