{
  "name": "timetracker",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform employee time tracking platform (monorepo root)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:admin": "pnpm --filter admin-web dev",
    "dev:employee": "pnpm --filter employee-web dev",
    "dev:desktop": "pnpm --filter desktop tauri dev",
    "build:admin": "pnpm --filter admin-web build",
    "build:employee": "pnpm --filter employee-web build",
    "build:desktop": "pnpm --filter desktop tauri build",
    "build:shared": "pnpm --filter @timetracker/shared build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "minio": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-minio.ps1",
    "server": "cargo run -p server"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
